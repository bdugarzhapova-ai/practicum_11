hole_letters = set('abdegopq')

text = input("Введите строку: ")

# Счёт букв с отверстиями и без
holes = 0
no_holes = 0

for char in text:
    if char.isalpha():
        if char in hole_letters:
            holes += 1
        else:
            no_holes += 1

print(holes, no_holes)

# Поиск слов с двумя и более отверстиями
words = text.split()
result_words = []

for word in words:
    # Считаем отверстия в слове
    count = 0
    for char in word:
        if char in hole_letters:
            count += 1
    if count >= 2:
        result_words.append(word)

print(result_words)
