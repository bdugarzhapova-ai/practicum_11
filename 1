numbers = []
print("Введите 10 целых чисел:")
for i in range(10):
    num = int(input(f"Число {i+1}: "))
    numbers.append(num)

print(f"Исходный список: {numbers}")

# Формируем новый список из 8 элементов
# Каждый элемент нового списка = сумма соседних элементов исходного
new_list = []
for i in range(1, 9):  # от 1 до 8 (не включая 9)
    sum_neighbors = numbers[i-1] + numbers[i+1]
    new_list.append(sum_neighbors)

print(f"Новый список (суммы соседних): {new_list}")
