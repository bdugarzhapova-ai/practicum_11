# Получаем строку от пользователя
text = input("Введите предложение: ")

# Удаляем знаки препинания
punctuation = ".,!?;:()[]{}'\"<>/@#$%^&*"

# Удаляем знаки препинания из каждого слова
for p in punctuation:
    text = text.replace(p, "")

# Разбиваем строку на слова и выводим список
words = text.split()
print(words)
